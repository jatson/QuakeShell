{
  "name": "quakeshell",
  "productName": "quakeshell",
  "version": "1.0.8",
  "description": "Quake-style drop-down terminal for Windows, distributed as a global npm command.",
  "main": ".vite/build/index.js",
  "bin": {
    "quakeshell": "scripts/npm/launcher.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "README.md",
    "scripts/npm/distribution.js",
    "scripts/npm/launcher.js",
    "scripts/npm/postinstall.js"
  ],
  "os": [
    "win32"
  ],
  "cpu": [
    "ia32",
    "x64"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "forge:publish": "electron-forge publish",
    "postinstall": "node scripts/npm/postinstall.js",
    "prepack": "node scripts/npm/publish-manifest.js prepare",
    "postpack": "node scripts/npm/publish-manifest.js restore",
    "release:asset": "node scripts/npm/package-release.js",
    "release:dry-run": "node scripts/npm/package-release.js --dry-run",
    "lint": "eslint --ext .ts,.tsx .",
    "test:npm": "vitest run --dir scripts/npm",
    "test": "vitest run"
  },
  "keywords": [
    "terminal",
    "electron",
    "windows",
    "quake",
    "powershell",
    "wsl"
  ],
  "author": {
    "name": "Jatson",
    "email": "back.barna@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jatson/QuakeShell.git"
  },
  "homepage": "https://github.com/jatson/QuakeShell#readme",
  "bugs": {
    "url": "https://github.com/jatson/QuakeShell/issues"
  },
  "devDependencies": {
    "@electron/asar": "^4.0.1",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@preact/preset-vite": "^2.10.5",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "electron": "^41.1.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "jsdom": "^29.0.1",
    "playwright": "^1.58.2",
    "typescript": "~4.5.4",
    "vite": "^5.4.21",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@preact/signals": "^2.9.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "electron-log": "^5.4.3",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^11.0.2",
    "node-pty": "^1.1.0",
    "preact": "^10.29.0",
    "zod": "^3.24.4"
  }
}
